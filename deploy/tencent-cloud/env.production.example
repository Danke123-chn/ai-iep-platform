# Copy to /var/www/ai-iep-platform/.env.production on the server before deploy.
# cp deploy/tencent-cloud/env.production.example .env.production

# CloudBase PG 模式（替代 Supabase）
NEXT_PUBLIC_CLOUDBASE_ENV_ID=your-env-id
NEXT_PUBLIC_CLOUDBASE_PUBLISHABLE_KEY=your-publishable-key

# 可选：逐步移除 Supabase 变量
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

DEEPSEEK_API_KEY=your-deepseek-api-key

# HTTP 访问（如 http://49.232.129.88）不要设为 true；HTTPS 上线后改为 true
# COOKIE_SECURE=true
