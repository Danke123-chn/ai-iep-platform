# Copy to project root as .env.cloudbase
# cp cloudbase/env.example .env.cloudbase

# CloudBase PG environment ID (控制台 → 环境概览)
CLOUDBASE_ENV_ID=your-env-id

# ⚠️ 迁移脚本 ExecutePGSql 需要「腾讯云 CAM API 密钥」，不是 CloudBase Publishable Key / API Key (JWT)
# 获取：https://console.cloud.tencent.com/cam/capi → 新建密钥
# SecretId 形如 AKID 开头（约 36 位），SecretKey 约 32 位；勿将真实密钥写入此文件
TENCENTCLOUD_SECRET_ID=your-tencent-secret-id
TENCENTCLOUD_SECRETKEY=your-tencent-secret-key

# PG mode region (must be ap-shanghai)
CLOUDBASE_REGION=ap-shanghai

# --- 以下用于 Next.js 应用，写入 .env.local ---
# NEXT_PUBLIC_CLOUDBASE_ENV_ID=your-env-id
# NEXT_PUBLIC_CLOUDBASE_PUBLISHABLE_KEY=eyJ...   (身份认证 → API Key → Publishable Key)
# DEEPSEEK_API_KEY=sk-...
